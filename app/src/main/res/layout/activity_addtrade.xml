<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- COIN -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/coinLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Coin"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <AutoCompleteTextView
            android:id="@+id/coinDropdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- LONG / SHORT -->
    <RadioGroup
        android:id="@+id/directionGroup"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/coinLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RadioButton
            android:id="@+id/longBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LONG"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/shortBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHORT"/>
    </RadioGroup>

    <!-- ENTRY -->
    <EditText
        android:id="@+id/entryInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Entry price"
        android:inputType="numberDecimal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/directionGroup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- TP -->
    <EditText
        android:id="@+id/tpInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Take Profit"
        android:inputType="numberDecimal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/entryInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SL -->
    <EditText
        android:id="@+id/slInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Stop Loss"
        android:inputType="numberDecimal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tpInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- USDT -->
    <EditText
        android:id="@+id/usdtInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="USDT Amount"
        android:inputType="numberDecimal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/slInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- LEVERAGE -->
    <EditText
        android:id="@+id/leverageInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Leverage (x)"
        android:inputType="number"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/usdtInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BUTTON -->
    <Button
        android:id="@+id/addTradeButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Add Trade"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/leverageInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>